{
    "extends": ["@nuxt/eslint-config", "../../.eslintrc.json"],
    "ignorePatterns": ["!**/*", ".nuxt/**", ".output/**", "node_modules"],
    "overrides": [
        {
            "files": ["*.ts", "*.tsx", "*.js", "*.jsx", "*.vue"],
            "rules": {
                "vue/multi-word-component-names": "off",
                "vue/html-indent": ["warn", 4],
                "vue/max-attributes-per-line": "off"
            }
        }
    ]
}
