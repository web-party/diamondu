{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "npmScope": "diamondu",
    "affected": {
        "defaultBase": "main"
    },
    "cli": {
        "packageManager": "npm"
    },
    "implicitDependencies": {
        "package.json": {
            "dependencies": "*",
            "devDependencies": "*"
        },
        ".eslintrc.json": "*"
    },
    "tasksRunnerOptions": {
        "default": {
            "runner": "@nrwl/nx-cloud",
            "options": {
                "cacheableOperations": ["build", "lint", "test", "e2e"],
                "accessToken": "NDAwMGVhY2MtYWJhZC00NGQ0LWIyZDQtY2FjYjIyYzU4OWQyfHJlYWQtd3JpdGU="
            }
        }
    },
    "generators": {
        "@nrwl/angular:application": {
            "style": "css",
            "linter": "eslint",
            "unitTestRunner": "jest",
            "e2eTestRunner": "cypress"
        },
        "@nrwl/angular:library": {
            "linter": "eslint",
            "unitTestRunner": "jest"
        },
        "@nrwl/angular:component": {
            "style": "css"
        }
    },
    "defaultProject": "kitchen-sink",
    "targetDefaults": {
        "build": {
            "dependsOn": ["^build"]
        },
        "e2e": {
            "inputs": ["default", "^default"]
        },
        "test": {
            "inputs": ["default", "^default", "{workspaceRoot}/jest.preset.js"]
        }
    }
}
